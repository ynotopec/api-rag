# API upstream OpenAI-compatible
OPENAI_API_BASE=http://localhost:8000/v1
OPENAI_API_KEY=changeme
UPSTREAM_TIMEOUT_SECONDS=60

# Public API auth/model names
API_AUTH_TOKEN=changeme
UPSTREAM_MODEL_RAG=gpt-4o-mini
# Omit to reuse UPSTREAM_MODEL_RAG in app.py default behavior.
# UPSTREAM_MODEL_REWRITE=gpt-4o-mini
MODEL_RAG=ai-rag
PORT=8080

# Vector store and ingestion
VECTORSTORE_DIR=vectorstore_db
WIKI_TXT=wiki.txt
RAG_FORCE_REBUILD=true
INGESTION_SOURCES=text
INGESTION_TEXT_PATHS=
THUNDERBIRD_PROFILE_DIR=
THUNDERBIRD_MAX_MESSAGES=10000
INGESTION_REFRESH_INTERVAL=0

# RAG behavior
RAG_TOP_K=8
RAG_QUERY_STRATEGY=rewrite+hyde
RAG_HISTORY_WINDOW=6
ENABLE_HYBRID_SEARCH=false
ENABLE_RERANKING=false
ENABLE_QUERY_CLASSIFICATION=true
ENABLE_CACHING=true

# Chunking/retrieval
CHUNK_SIZE=800
CHUNK_OVERLAP=100
MMR_K=8
MMR_FETCH_K=16
BM25_K=4

# Embeddings
EMBEDDING_BACKEND=external
EMBEDDING_MODEL=BAAI/bge-m3
# Defaults to OPENAI_API_BASE when omitted.
# EMBEDDINGS_API_BASE=http://localhost:8000/v1
EMBEDDING_DEVICE=cpu

# Reranking
RERANKING_BACKEND=external
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Defaults to OPENAI_API_BASE when omitted.
# RERANKING_API_BASE=http://localhost:8000/v1
RERANKER_DEVICE=cpu

# Runtime resources
MAX_WORKERS=4

# Required: upstream OpenAI-compatible API used for generation, embeddings, and reranking by default.
OPENAI_API_BASE=http://localhost:8000/v1
OPENAI_API_KEY=changeme-upstream-token

# Required in production: inbound token clients send as Authorization: Bearer <token> or X-API-Key.
API_AUTH_TOKEN=changeme-inbound-token

# Required if your upstream model names differ from the defaults.
UPSTREAM_MODEL_RAG=gpt-4o-mini
MODEL_RAG=ai-rag

# Optional/default: listen address and port. Positional args to run.sh override these.
#HOST=0.0.0.0
#PORT=8080

# Optional/default: document ingestion. Use INGESTION_TEXT_PATHS for one or more files/directories.
#INGESTION_SOURCES=text
#WIKI_TXT=wiki.txt
#INGESTION_TEXT_PATHS=docs,README.md
#VECTORSTORE_DIR=vectorstore_db
#RAG_FORCE_REBUILD=false

# Optional/default: retrieval quality/performance.
#RAG_TOP_K=8
#RAG_QUERY_STRATEGY=rewrite+hyde
#ENABLE_HYBRID_SEARCH=false
#ENABLE_RERANKING=false
#ENABLE_CACHING=true

# Optional/default: external backends are best for H100/DGX Spark/vLLM deployments.
#EMBEDDING_BACKEND=external
#EMBEDDING_MODEL=BAAI/bge-m3
#EMBEDDINGS_API_BASE=http://localhost:8000/v1
#RERANKING_BACKEND=external
#RERANKER_MODEL=BAAI/bge-reranker-v2-m3
#RERANKING_API_BASE=http://localhost:8000/v1

# Optional: local GPU inference when this API loads embedding/reranker models itself.
#EMBEDDING_BACKEND=local
#EMBEDDING_DEVICE=cuda
#RERANKING_BACKEND=local
#RERANKER_DEVICE=cuda

# Optional/default: runtime tuning.
#MAX_WORKERS=4
#UPSTREAM_TIMEOUT_SECONDS=60
#UVICORN_WORKERS=1
#UVICORN_LOG_LEVEL=info
